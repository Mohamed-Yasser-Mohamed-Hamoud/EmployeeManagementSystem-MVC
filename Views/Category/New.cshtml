@model Category
@{
	ViewData["Titel"] = "New";
}
<form method="post" enctype="multipart/form-data">
	<div class="boarder p-3 mt-4">
		<div class="row pb-2">
			<h2 class="text-primary">Add new Category</h2>
			<hr />
		</div>
		<div asp-validation-summary="All"></div>
		<div class="mb-3">
			<label asp-for="category_name"></label>
			<input asp-for="category_name" class="form-control" />
			<span asp-validation-for="category_name" class="text-danger"></span>
		</div>
		<div>
			<input asp-for="clientFile" type="file" onchange="loadFile(event)">
			<img id="myImage" height="200" />
		</div>
		<br />
		<hr />
		<button type="submit" class="btn btn-primary">Save</button>
		<a asp-controller="Category" asp-action="Index" class="btn btn-secondary" style="width:150px">back to Catrgories</a>
	</div>
</form>
@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script>
		var loadFile = function(event) {
			var reader = new FileReader();
			reader.onload = function(){
				var myImg = document.getElementById('myImage');
				myImg.src = reader.result;
			}
			reader.readAsDataURL(event.target.files[0]);
		};
	</script>
		
}